{
  "kind": "collectionType",
  "collectionName": "comparisons",
  "info": {
    "singularName": "comparison",
    "pluralName": "comparisons",
    "displayName": "工具对比",
    "description": "两个工具之间的决策对比页面。"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true
    },
    "recommendation": {
      "type": "text"
    },
    "featureNotes": {
      "type": "json"
    },
    "pricingNotes": {
      "type": "text"
    },
    "verdict": {
      "type": "text"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    },
    "toolA": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tool.tool"
    },
    "toolB": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::tool.tool"
    }
  }
}
